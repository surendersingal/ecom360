#ecom360-chatbot-fab svg{width:28px;height:28px;fill:#fff}
#ecom360-chatbot-panel{position:fixed;<?= $posStyle ?>z-index:999999;width:380px;height:520px;background:#fff;border-radius:16px;box-shadow:0 12px 50px rgba(0,0,0,.2);display:none;flex-direction:column;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
#ecom360-chatbot-panel.open{display:flex}
.ecom360-chat-header{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;padding:16px 20px;display:flex;justify-content:space-between;align-items:center}
.ecom360-chat-header h4{margin:0;font-size:16px;font-weight:600}
