.ecom360-chat-msg{max-width:80%;padding:10px 14px;border-radius:16px;font-size:14px;line-height:1.5;word-wrap:break-word}
.ecom360-chat-msg.bot{align-self:flex-start;background:#f0f0f7;color:#333;border-bottom-left-radius:4px}
.ecom360-chat-msg.user{align-self:flex-end;background:#667eea;color:#fff;border-bottom-right-radius:4px}
