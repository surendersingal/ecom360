<?php
/** @var \Ecom360\Analytics\Block\PushNotification $block */
if (!$block->isEnabled()) {
    return;
}
$config = $block->getPushConfigJson();
?>
<!-- Ecom360 Push Notification -->
<script id="ecom360-push-config" type="application/json">
    <?= /* @noEscape */ $config ?>
</script>
<script>
(function() {
    'use strict';

    if (!('Notification' in window) || !('serviceWorker' in navigator)) return;

    var cfgEl = document.getElementById('ecom360-push-config');
    if (!cfgEl) return;
    var CFG;
    try { CFG = JSON.parse(cfgEl.textContent); } catch(_) { return; }

    function subscribe() {
        if (CFG.provider === 'firebase') {
            subscribeFirebase();
        } else if (CFG.provider === 'onesignal') {
            subscribeOneSignal();
        }
    }

    // ---------- Firebase ----------
    function subscribeFirebase() {
        if (!CFG.firebase || !CFG.firebase.sender_id) return;

        navigator.serviceWorker.register(CFG.firebase.sw_path || '/ecom360-firebase-sw.js')
            .then(function(reg) {
                return reg.pushManager.subscribe({
                    userVisibleOnly: true,
                    applicationServerKey: urlBase64ToUint8Array(CFG.firebase.sender_id)
                });
            })
            .then(function(sub) {
                sendSubscription({
                    provider: 'firebase',
                    endpoint: sub.endpoint,
                    subscription_data: JSON.stringify(sub.toJSON()),
                    token: sub.endpoint.split('/').pop(),
                    user_agent: navigator.userAgent
                });
            })
            .catch(function(err) {
                console.warn('[ecom360] Push subscription failed:', err);
            });
    }

    // ---------- OneSignal ----------
    function subscribeOneSignal() {
        if (!CFG.onesignal || !CFG.onesignal.app_id) return;

        // Load OneSignal SDK
        var script = document.createElement('script');
        script.src = 'https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js';
        script.defer = true;
        script.onload = function() {
            window.OneSignalDeferred = window.OneSignalDeferred || [];
            window.OneSignalDeferred.push(function(OneSignal) {
                OneSignal.init({
                    appId: CFG.onesignal.app_id,
                    allowLocalhostAsSecureOrigin: true
                });
                OneSignal.User.PushSubscription.addEventListener('change', function(event) {
                    if (event.current.token) {
                        sendSubscription({
                            provider: 'onesignal',
                            endpoint: '',
                            subscription_data: JSON.stringify(event.current),
                            token: event.current.token,
                            user_agent: navigator.userAgent
                        });
                    }
                });
            });
        };
        document.head.appendChild(script);
    }

    function sendSubscription(data) {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', CFG.subscribe_url, true);
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.send(JSON.stringify(data));
    }

    function urlBase64ToUint8Array(base64String) {
        var padding = '='.repeat((4 - base64String.length % 4) % 4);
        var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
        var raw = atob(base64);
        var arr = new Uint8Array(raw.length);
        for (var i = 0; i < raw.length; ++i) arr[i] = raw.charCodeAt(i);
        return arr;
    }

    // ---------- auto-prompt ----------
    if (Notification.permission === 'default') {
        setTimeout(function() {
            Notification.requestPermission().then(function(permission) {
                if (permission === 'granted') subscribe();
            });
        }, (CFG.prompt_delay || 10) * 1000);
    } else if (Notification.permission === 'granted') {
        subscribe();
    }
})();
</script>
<!-- /Ecom360 Push Notification -->
