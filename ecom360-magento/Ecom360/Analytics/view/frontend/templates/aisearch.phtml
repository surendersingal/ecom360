if (!$block->isEnabled()) {
    return;
}
$configJson = $block->getConfigJson();
/* Local Magento admin fallbacks — overridden at runtime by widget-config API */
$visualFallback = $block->isVisualSearchEnabled();
$voiceFallback = $block->isVoiceSearchEnabled();
