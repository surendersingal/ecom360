<script>
(function(){
    var cfg = <?= /* @noEscape */ $configJson ?>;
    var overlay = document.getElementById('ecom360-search-overlay');
    var input = document.getElementById('ecom360-search-input');
    var resultsDiv = document.getElementById('ecom360-search-results');
    var suggestionsDiv = document.getElementById('ecom360-search-suggestions');
    var metaDiv = document.getElementById('ecom360-search-meta');
    var closeBtn = document.getElementById('ecom360-search-close');
    var debounceTimer = null;

    /* INR formatter */
    function formatINR(num) {
        num = parseFloat(num);
        if (isNaN(num) || num <= 0) return '';
        var s = Math.round(num).toString();
        var lastThree = s.substring(s.length - 3);
        var otherNumbers = s.substring(0, s.length - 3);
        if (otherNumbers !== '') lastThree = ',' + lastThree;
        return '\u20B9' + otherNumbers.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + lastThree;
    }

    function escapeHtml(s) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(s || ''));
        return d.innerHTML;
    }

    /* Enter -> go to full SRP */
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            var q = input.value.trim();
            if (q.length > 0) {
                window.location.href = '/ecom360/search/results?q=' + encodeURIComponent(q);
            }
        }
    });

    /* Hijack native Magento search */
    document.addEventListener('DOMContentLoaded', function() {
        var searchForms = document.querySelectorAll('#search_mini_form, .search-form, form[action*="catalogsearch"]');
        searchForms.forEach(function(form) {
            var si = form.querySelector('input[name="q"], input#search');
            if (si) {
                si.addEventListener('focus', function(e) {
                    e.preventDefault();
                    openSearch(si.value);
                });
            }
        });
    });

    /* Keyboard shortcuts */
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            openSearch('');
        }
        if (e.key === 'Escape' && overlay.classList.contains('open')) {
            closeSearch();
        }
    });

    function openSearch(q) {
        overlay.classList.add('open');
        input.value = q || '';
        input.focus();
        if (q && q.trim().length >= 2) {
            doSearch(q.trim());
        } else {
            loadTrending();
        }
    }

    function closeSearch() {
        overlay.classList.remove('open');
    }

    closeBtn.addEventListener('click', closeSearch);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) closeSearch(); });

    input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var q = input.value.trim();
        if (q.length < 2) {
            loadTrending();
            metaDiv.style.display = 'none';
            return;
        }
        debounceTimer = setTimeout(function() { doSearch(q); }, 250);
    });

    function doSearch(q) {
        resultsDiv.innerHTML = '<div class="ecom360-search-empty">Searching...</div>';
        metaDiv.style.display = 'none';
        suggestionsDiv.innerHTML = '';

        var xhr = new XMLHttpRequest();
        xhr.open('GET', cfg.endpoint + '/search?q=' + encodeURIComponent(q) + '&per_page=8', true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                var products = res.results || [];
                var facets = res.facets || {};
                var total = res.total || 0;
                var responseTime = res.response_time_ms || 0;
                var brands = facets.brands || [];
                var categories = facets.categories || [];
                var interpreted = res.interpreted_as || null;

                renderGroupedResults(q, products, brands, categories, total);
                renderSearchMeta(total, responseTime, interpreted, res.fallback_hint);
            } catch(e) {
                resultsDiv.innerHTML = '<div class="ecom360-search-empty">Search error. Please try again.</div>';
            }
        };
        xhr.onerror = function() {
            resultsDiv.innerHTML = '<div class="ecom360-search-empty">Network error. Check your connection.</div>';
        };
        xhr.send();
    }

    /* Main grouped render: Products -> Brands -> Categories */
    function renderGroupedResults(q, products, brands, categories, total) {
        if (!products.length && !brands.length && !categories.length) {
            resultsDiv.innerHTML = '<div class="ecom360-search-empty">' +
                '<svg viewBox="0 0 24 24" width="40" height="40" fill="#ddd"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>' +
                'No results found for "<strong>' + escapeHtml(q) + '</strong>"</div>';
            return;
        }

        var html = '';

        /* === PRODUCTS SECTION (Priority 1) === */
        if (products.length) {
            html += '<div class="ecom360-group">';
            html += '<div class="ecom360-group-header">';
            html += '<span class="ecom360-group-title">Products</span>';
            html += '<span class="ecom360-group-count">' + total + ' found</span>';
            html += '</div>';

            products.forEach(function(item) {
                var url = item.url || '#';
                var img = item.image || '';
                var name = item.name || '';
                var brand = item.brand || '';
                var cat = item.category || '';

                /* Price */
                var priceHtml = '';
                var price = parseFloat(item.price);
                var special = parseFloat(item.special_price);
                if (special > 0 && special < price) {
                    var disc = Math.round((1 - special / price) * 100);
                    priceHtml = '<span class="ecom360-original">' + formatINR(price) + '</span>';
                    priceHtml += '<span class="ecom360-current">' + formatINR(special) + '</span>';
                    if (disc > 0) priceHtml += '<span class="ecom360-discount">-' + disc + '%</span>';
                } else if (price > 0) {
                    priceHtml = '<span class="ecom360-current">' + formatINR(price) + '</span>';
                }

                html += '<a class="ecom360-product-item" href="' + url + '">';
                if (img && img.indexOf('no_selection') === -1) {
                    html += '<img src="' + img + '" alt="" loading="lazy" onerror="this.parentElement.querySelector(\'.ecom360-no-img\')&&(this.parentElement.querySelector(\'.ecom360-no-img\').style.display=\'flex\');this.style.display=\'none\'" />';
                } else {
                    html += '<div class="ecom360-no-img"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zm-12.5-5.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg></div>';
                }
                html += '<div class="ecom360-product-info">';
                html += '<div class="ecom360-pname">' + escapeHtml(name) + '</div>';
                if (brand) html += '<div class="ecom360-pbrand">' + escapeHtml(brand) + '</div>';
                else if (cat) html += '<div class="ecom360-pcat">' + escapeHtml(cat) + '</div>';
                html += '</div>';
                if (priceHtml) html += '<div class="ecom360-product-price">' + priceHtml + '</div>';
                html += '</a>';
            });
            html += '</div>';
        }

        /* === BRANDS SECTION (Priority 2) === */
        if (brands.length) {
            html += '<div class="ecom360-group">';
            html += '<div class="ecom360-group-header">';
            html += '<span class="ecom360-group-title">Brands</span>';
            html += '<span class="ecom360-group-count">' + brands.length + ' matching</span>';
            html += '</div>';
            html += '<div class="ecom360-brand-list">';

            /* Show top 8 brands */
            var showBrands = brands.slice(0, 8);
            showBrands.forEach(function(b) {
                var label = b.label || b.value || b;
                var value = b.value || label;
                var count = b.count || '';
                html += '<a class="ecom360-brand-item" href="/ecom360/search/results?q=' + encodeURIComponent(q) + '&brands=' + encodeURIComponent(value) + '">';
                html += escapeHtml(label);
                if (count) html += ' <span class="ecom360-bcount">(' + count + ')</span>';
                html += '</a>';
            });

            html += '</div></div>';
        }

        /* === CATEGORIES SECTION (Priority 3) === */
        if (categories.length) {
            html += '<div class="ecom360-group">';
            html += '<div class="ecom360-group-header">';
            html += '<span class="ecom360-group-title">Categories</span>';
            html += '<span class="ecom360-group-count">' + categories.length + ' matching</span>';
            html += '</div>';

            /* Show top 5 categories */
            var showCats = categories.slice(0, 5);
            showCats.forEach(function(c) {
                var label = c.label || c.value || c;
                var value = c.value || label;
                var count = c.count || '';
                html += '<a class="ecom360-cat-item" href="/ecom360/search/results?q=' + encodeURIComponent(q) + '&categories=' + encodeURIComponent(value) + '">';
                html += '<span class="ecom360-cat-icon"><svg viewBox="0 0 24 24"><path d="M10 4H4c-1.1 0-2 .9-2 2v4h8V4zm8 0h-6v6h8V6c0-1.1-.9-2-2-2zm-6 8H2v4c0 1.1.9 2 2 2h6v-6zm8 0h-6v6h6c1.1 0 2-.9 2-2v-4z"/></svg></span>';
                html += '<span class="ecom360-cat-name">' + escapeHtml(label) + '</span>';
                if (count) html += '<span class="ecom360-cat-count">' + count + ' products</span>';
                html += '<span class="ecom360-cat-arrow">&rsaquo;</span>';
                html += '</a>';
            });
            html += '</div>';
        }

        /* View All link */
        if (total > 0) {
            html += '<a class="ecom360-view-all" href="/ecom360/search/results?q=' + encodeURIComponent(q) + '">View All ' + total + ' Results &rarr;</a>';
        }

        resultsDiv.innerHTML = html;
    }

    function renderSearchMeta(total, responseTime, interpreted, fallbackHint) {
        if (total > 0 || interpreted || fallbackHint) {
            metaDiv.style.display = 'block';
            var parts = [];
            if (total > 0) parts.push(total + ' result' + (total !== 1 ? 's' : ''));
            if (responseTime) parts.push(responseTime + 'ms');
            if (interpreted) parts.push('<em>' + escapeHtml(interpreted) + '</em>');
            var html = parts.join(' &middot; ');
            if (fallbackHint) html += '<br><span style="color:#e67e22;font-size:11px">' + escapeHtml(fallbackHint) + '</span>';
            metaDiv.innerHTML = html;
        } else {
            metaDiv.style.display = 'none';
        }
    }

    function loadTrending() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', cfg.endpoint + '/trending?limit=10', true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                var items = (res.data && res.data.trending) || res.trending || [];
                if (items.length) {
                    suggestionsDiv.innerHTML = '<div class="ecom360-search-trending-label">Trending Searches</div>' +
                        items.map(function(s){ var q = s.query || s; return '<span data-q="'+escapeHtml(q)+'">'+escapeHtml(q)+'</span>'; }).join('');
                    suggestionsDiv.querySelectorAll('span[data-q]').forEach(function(el) {
                        el.addEventListener('click', function() {
                            input.value = el.dataset.q;
                            doSearch(el.dataset.q);
                        });
                    });
                    resultsDiv.innerHTML = '<div class="ecom360-search-empty">' +
                        '<svg viewBox="0 0 24 24" width="40" height="40" fill="#ddd"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>' +
                        'Search products, brands & categories</div>';
                }
            } catch(e) {}
        };
        xhr.send();
    }

    <?php /* ── Feature-flag bootstrap: fetch config from API, fall back to local ── */ ?>

    var visualBtn = document.getElementById('ecom360-visual-search-btn');
    var visualFile = document.getElementById('ecom360-visual-search-file');
    var voiceBtn  = document.getElementById('ecom360-voice-search-btn');
    var widgetConfigLoaded = false;

    /**
     * Enable or disable a feature button.
     */
    function setFeature(el, on) {
        if (!el) return;
        if (on) el.classList.add('ecom360-feature-on');
        else    el.classList.remove('ecom360-feature-on');
    }

    /**
     * Apply local Magento admin fallback values immediately so the UI
     * matches local config before the API response arrives.
     */
    setFeature(visualBtn, <?= $visualFallback ? 'true' : 'false' ?>);
    setFeature(voiceBtn,  <?= $voiceFallback  ? 'true' : 'false' ?>);

    /**
     * Fetch widget-config from the ecom360 backend API (same pattern
     * as the chatbot widget). Overrides local Magento admin values so
     * that toggling settings in the dashboard takes immediate effect.
     */
    function loadWidgetConfig() {
        if (widgetConfigLoaded) return;
        widgetConfigLoaded = true;
        var xhr = new XMLHttpRequest();
        xhr.open('GET', cfg.endpoint + '/widget-config', true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                var wc = res.data || res;
                if (typeof wc.visual_search_enabled !== 'undefined') {
                    setFeature(visualBtn, !!wc.visual_search_enabled);
                    cfg.visualSearch = !!wc.visual_search_enabled;
                }
                if (typeof wc.voice_search_enabled !== 'undefined') {
                    setFeature(voiceBtn, !!wc.voice_search_enabled);
                    cfg.voiceSearch = !!wc.voice_search_enabled;
                }
                if (wc.widget_placeholder && input) {
                    input.placeholder = wc.widget_placeholder;
                }
            } catch(e) { /* keep local fallback values */ }
        };
        xhr.send();
    }

    /* Load widget config once on first search open */
    var _origOpen = openSearch;
    openSearch = function(q) {
        loadWidgetConfig();
        _origOpen(q);
    };

    /* ── Visual Search Handler ── */
    visualBtn.addEventListener('click', function() { visualFile.click(); });
    visualFile.addEventListener('change', function() {
        if (!this.files.length) return;
        var file = this.files[0];
        if (file.size > 10 * 1024 * 1024) {
            resultsDiv.innerHTML = '<div class="ecom360-search-empty">Image too large (max 10 MB)</div>';
            this.value = '';
            return;
        }
        resultsDiv.innerHTML = '<div class="ecom360-search-empty">Analyzing image...</div>';
        var reader = new FileReader();
        reader.onload = function(e) {
            var base64 = e.target.result; /* data:image/...;base64,XXXX */
            var xhr = new XMLHttpRequest();
            xhr.open('POST', cfg.endpoint + '/visual-search', true);
            xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
            xhr.setRequestHeader('Content-Type', 'application/json');
            xhr.setRequestHeader('Accept', 'application/json');
            xhr.onload = function() {
                try {
                    var res = JSON.parse(xhr.responseText);
                    var products = res.results || (res.data && res.data.results) || [];
                    var features = res.detected_features || (res.data && res.data.detected_features) || null;
                    if (products.length) {
                        renderGroupedResults('', products, [], [], products.length);
                        if (features) {
                            metaDiv.style.display = 'block';
                            var parts = [products.length + ' visual match' + (products.length !== 1 ? 'es' : '')];
                            if (features.dominant_colors) parts.push('Colors: ' + features.dominant_colors.join(', '));
                            if (features.category_guess) parts.push('Category: ' + features.category_guess);
                            metaDiv.innerHTML = parts.join(' &middot; ');
                        }
                    } else {
                        resultsDiv.innerHTML = '<div class="ecom360-search-empty">No visually similar products found.' +
                            (features && features.dominant_colors ? '<br><small style="color:#999">Detected: ' + features.dominant_colors.join(', ') + '</small>' : '') +
                            '</div>';
                    }
                } catch(e) {
                    resultsDiv.innerHTML = '<div class="ecom360-search-empty">Image search failed. Please try again.</div>';
                }
            };
            xhr.onerror = function() {
                resultsDiv.innerHTML = '<div class="ecom360-search-empty">Network error during image search.</div>';
            };
            xhr.send(JSON.stringify({ image_base64: base64 }));
        };
        reader.readAsDataURL(file);
        this.value = '';
    });

    /* ── Voice Search Handler (Web Speech API) ── */
    var recognition = null;
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        recognition = new SpeechRecognition();
        recognition.lang = 'en-US';
        recognition.interimResults = false;
        recognition.maxAlternatives = 1;

        recognition.onresult = function(event) {
            var transcript = event.results[0][0].transcript;
            input.value = transcript;
            voiceBtn.classList.remove('listening');
            if (transcript.trim().length >= 2) {
                doSearch(transcript.trim());
            }
        };
        recognition.onerror = function() { voiceBtn.classList.remove('listening'); };
        recognition.onend   = function() { voiceBtn.classList.remove('listening'); };
    }

    voiceBtn.addEventListener('click', function() {
        if (!recognition) {
            alert('Voice search is not supported in this browser.');
            return;
        }
        if (voiceBtn.classList.contains('listening')) {
            recognition.stop();
        } else {
            voiceBtn.classList.add('listening');
            recognition.start();
        }
    });

    window.ecom360OpenSearch = openSearch;
})();
</script>
