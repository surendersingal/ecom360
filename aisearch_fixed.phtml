        </div>
    </div>
</div>

<script>
(function(){
    var cfg = <?= /* @noEscape */ $configJson ?>;
    var overlay = document.getElementById('ecom360-search-overlay');
    var input = document.getElementById('ecom360-search-input');
    var resultsDiv = document.getElementById('ecom360-search-results');
    var suggestionsDiv = document.getElementById('ecom360-search-suggestions');
    var facetsDiv = document.getElementById('ecom360-search-facets');
    var metaDiv = document.getElementById('ecom360-search-meta');
    var closeBtn = document.getElementById('ecom360-search-close');
    var debounceTimer = null;
    var activeFacets = {};

    // Format price in INR (Indian comma separation, no decimals)
    function formatINR(num) {
        num = parseFloat(num);
        if (isNaN(num) || num <= 0) return '';
        // Indian number format: 1,00,000
        var s = Math.round(num).toString();
        var afterPoint = '';
        if (s.indexOf('.') > 0) {
            afterPoint = s.substring(s.indexOf('.'), s.length);
            s = s.substring(0, s.indexOf('.'));
        }
        var lastThree = s.substring(s.length - 3);
        var otherNumbers = s.substring(0, s.length - 3);
        if (otherNumbers !== '') lastThree = ',' + lastThree;
        return otherNumbers.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + lastThree;
    }

    // Hijack default Magento search
    document.addEventListener('DOMContentLoaded', function() {
        var searchForms = document.querySelectorAll('#search_mini_form, .search-form, form[action*="catalogsearch"]');
        searchForms.forEach(function(form) {
            var searchInput = form.querySelector('input[name="q"], input#search');
            if (searchInput) {
                searchInput.addEventListener('focus', function(e) {
                    e.preventDefault();
                    openSearch(searchInput.value);
                });
            }
        });
    });

    // Keyboard shortcut: Ctrl+K or Cmd+K
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            openSearch('');
        }
        if (e.key === 'Escape' && overlay.classList.contains('open')) {
            closeSearch();
        }
    });

    function openSearch(q) {
        overlay.classList.add('open');
        input.value = q || '';
        input.focus();
        loadTrending();
    }

    function closeSearch() {
        overlay.classList.remove('open');
    }

    closeBtn.addEventListener('click', closeSearch);
    overlay.addEventListener('click', function(e) { if (e.target === overlay) closeSearch(); });

    input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var q = input.value.trim();
        if (q.length < 2) {
            loadTrending();
            facetsDiv.style.display = 'none';
            metaDiv.style.display = 'none';
            return;
        }
        debounceTimer = setTimeout(function() { doSearch(q); }, 300);
    });

    // Suggest / auto-complete as they type
    input.addEventListener('input', function() {
        var q = input.value.trim();
        if (q.length < 2) { suggestionsDiv.innerHTML = ''; return; }
        var xhr = new XMLHttpRequest();
        xhr.open('GET', cfg.endpoint + '/suggest?q=' + encodeURIComponent(q) + '&limit=6', true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                var items = res.popular || res.suggestions || (res.data && res.data.suggestions) || [];
                suggestionsDiv.innerHTML = items.map(function(s){ var t = s.term || s.name || s; return "<span data-q='"+t+"'>"+t+"</span>"; }).join("");
                suggestionsDiv.querySelectorAll('span').forEach(function(el) {
                    el.addEventListener('click', function() { input.value = el.dataset.q; doSearch(el.dataset.q); });
                });
            } catch(e) {}
        };
        xhr.send();
    });

    function doSearch(q) {
        var params = 'q=' + encodeURIComponent(q) + '&limit=20';
        // Add active facet filters
        Object.keys(activeFacets).forEach(function(k) {
            var val = activeFacets[k];
            if (k === 'price_ranges' && val) {
                // Parse price range value "min-max" into min_price & max_price
                var parts = val.split('-');
                if (parts[0]) params += '&min_price=' + encodeURIComponent(parts[0]);
                if (parts[1]) params += '&max_price=' + encodeURIComponent(parts[1]);
            } else {
                params += '&' + k + '=' + encodeURIComponent(val);
            }
        });

        resultsDiv.innerHTML = '<div class="ecom360-search-empty">Searching...</div>';
        var xhr = new XMLHttpRequest();
        xhr.open('GET', cfg.endpoint + '/search?' + params, true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                var items = res.results || (res.data && res.data.results) || [];
                var facets = res.facets || (res.data && res.data.facets) || {};
                var total = res.total || (res.data && res.data.total) || items.length;
                var responseTime = res.response_time_ms || 0;
                renderResults(items);
                renderFacets(facets, q);
                renderMeta(total, responseTime);
            } catch(e) {
                resultsDiv.innerHTML = '<div class="ecom360-search-empty">Search error</div>';
            }
        };
        xhr.onerror = function() {
            resultsDiv.innerHTML = '<div class="ecom360-search-empty">Network error</div>';
        };
        xhr.send();
    }

    function renderResults(items) {
        if (!items.length) {
            resultsDiv.innerHTML = '<div class="ecom360-search-empty">No results found</div>';
            return;
        }
        var html = '';
        items.forEach(function(item) {
            var img = item.image || item.thumbnail || '';
            var url = item.url || '#';

            // Build price HTML with INR formatting
            var priceHtml = '';
            if (item.special_price && parseFloat(item.special_price) > 0 && parseFloat(item.special_price) < parseFloat(item.price)) {
                var discount = Math.round((1 - parseFloat(item.special_price) / parseFloat(item.price)) * 100);
                priceHtml = '<span class="ecom360-original-price">\u20B9' + formatINR(item.price) + '</span>';
                priceHtml += '<span class="ecom360-current-price">\u20B9' + formatINR(item.special_price) + '</span>';
                if (discount > 0) priceHtml += '<span class="ecom360-discount-badge">-' + discount + '%</span>';
            } else if (item.price && parseFloat(item.price) > 0) {
                priceHtml = '<span class="ecom360-current-price">\u20B9' + formatINR(item.price) + '</span>';
            }

            html += '<div class="ecom360-search-item" data-url="' + url + '">';
            if (img) {
                html += '<img src="' + img + '" alt="" loading="lazy" onerror="this.style.display=\'none\'"/>';
            } else {
                html += '<div class="ecom360-no-img"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zm-12.5-5.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg></div>';
            }
            html += '<div class="ecom360-search-item-info"><h5>' + (item.name || item.title || '') + '</h5>';
            if (item.category) html += '<p>' + item.category + '</p>';
            html += '</div>';
            if (priceHtml) html += '<div class="ecom360-search-item-price">' + priceHtml + '</div>';
            html += '</div>';
        });
        resultsDiv.innerHTML = html;
        resultsDiv.querySelectorAll('.ecom360-search-item').forEach(function(el) {
            el.addEventListener('click', function() {
                var url = el.dataset.url;
                if (url && url !== '#') window.location.href = url;
            });
        });
    }

    function renderFacets(facets, q) {
        var keys = Object.keys(facets);
        if (!keys.length) { facetsDiv.style.display = 'none'; return; }
        facetsDiv.style.display = 'flex';
        var html = '';
        keys.forEach(function(k) {
            var vals = facets[k] || [];
            if (!Array.isArray(vals)) return; // Skip non-array facets
            vals.forEach(function(v) {
                var label = v.label || v.value || v;
                var value = v.value || label;
                var isActive = activeFacets[k] === value;
                html += '<span class="ecom360-search-facet' + (isActive ? ' active' : '') + '" data-key="' + k + '" data-val="' + value + '">' + label + (v.count ? ' (' + v.count + ')' : '') + '</span>';
            });
        });
        facetsDiv.innerHTML = html;
        facetsDiv.querySelectorAll('.ecom360-search-facet').forEach(function(el) {
            el.addEventListener('click', function() {
                if (activeFacets[el.dataset.key] === el.dataset.val) {
                    delete activeFacets[el.dataset.key];
                } else {
                    activeFacets[el.dataset.key] = el.dataset.val;
                }
                doSearch(q);
            });
        });
    }

    function renderMeta(total, responseTime) {
        if (total > 0) {
            metaDiv.style.display = 'block';
            metaDiv.innerHTML = total + ' result' + (total !== 1 ? 's' : '') + (responseTime ? ' &middot; ' + responseTime + 'ms' : '');
        } else {
            metaDiv.style.display = 'none';
        }
    }

    function loadTrending() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', cfg.endpoint + '/trending?limit=10', true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                var items = (res.data && res.data.trending) || res.trending || [];
                if (items.length) {
                    suggestionsDiv.innerHTML = '<div class="ecom360-search-trending-label">Trending Searches</div>' +
                        items.map(function(s){ var q = s.query || s; return '<span data-q="'+q+'">'+q+'</span>'; }).join('');
                    suggestionsDiv.querySelectorAll('span').forEach(function(el) {
                        if (el.dataset.q) el.addEventListener('click', function() { input.value = el.dataset.q; doSearch(el.dataset.q); });
                    });
                    resultsDiv.innerHTML = '<div class="ecom360-search-empty">Type to search or pick a trending query</div>';
                }
            } catch(e) {}
        };
        xhr.send();
    }

    <?php if ($visualEnabled): ?>
    // Visual search
    var visualBtn = document.getElementById('ecom360-visual-search-btn');
    var visualFile = document.getElementById('ecom360-visual-search-file');
    visualBtn.addEventListener('click', function() { visualFile.click(); });
    visualFile.addEventListener('change', function() {
        if (!this.files.length) return;
        var formData = new FormData();
        formData.append('image', this.files[0]);
        resultsDiv.innerHTML = '<div class="ecom360-search-empty">Analyzing image...</div>';
        var xhr = new XMLHttpRequest();
        xhr.open('POST', cfg.endpoint + '/visual-search', true);
        xhr.setRequestHeader('X-Ecom360-Key', cfg.apiKey);
        xhr.onload = function() {
            try {
                var res = JSON.parse(xhr.responseText);
                renderResults(res.results || (res.data && res.data.results) || []);
            } catch(e) {
                resultsDiv.innerHTML = '<div class="ecom360-search-empty">Image search failed</div>';
            }
        };
        xhr.send(formData);
        this.value = '';
    });
    <?php endif; ?>

    // Expose globally
    window.ecom360OpenSearch = openSearch;
})();
</script>
