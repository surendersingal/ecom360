{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "laravel",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--port=8090"],
      "port": 8090
    },
    {
      "name": "vite",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite"],
      "port": 5173
    },
    {
      "name": "reverb",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "reverb:start"],
      "port": 8080
    },
    {
      "name": "queue",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1"],
      "port": 6001
    }
  ]
}
